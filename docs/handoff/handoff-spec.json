  "ai_agents": {
    "discussion_engine": {
      "trigger_conditions": [
        "新しいスレッドが作成された時",
        "スレッドに新しいメッセージが投稿された時（オプション）"
      ],
      "llm_prompts": {
        "initial_analysis": "You are an AI analyst evaluating a new AI service or technology. Analyze the following service and provide a comprehensive initial assessment:\n\nService: {service_name}\nDescription: {description}\n\nProvide:\n1. Key strengths\n2. Potential weaknesses\n3. Use cases\n4. Competitive advantages\n5. Risk factors\n\nBe objective and data-driven. Avoid hype.",
        "response_generation": "You are an AI expert in {domain}. The following discussion is happening about {service_name}:\n\n{previous_messages}\n\nProvide a thoughtful response that:\n1. Addresses the previous points\n2. Adds new insights\n3. Raises important considerations\n4. Maintains objectivity\n\nKeep response to 200-300 words.",
        "summary_generation": "Summarize the following discussion about {service_name} in 200-300 words:\n\n{all_messages}\n\nInclude:\n1. Main consensus points (3-5 bullet points)\n2. Key disagreements (2-3 bullet points)\n3. Critical insights (3-5 bullet points)\n4. Overall assessment\n\nFormat as JSON with keys: summary, consensus_points, disagreement_points, insights"
      },
      "evaluation_axes": [
        {
          "name": "性能",
          "description": "技術的な性能・精度・スピード・スケーラビリティ",
          "scoring_rubric": "0-20: 基本的な機能なし、20-40: 基本機能のみ、40-60: 平均的な性能、60-80: 優れた性能、80-100: 業界最高水準"
        },
        {
          "name": "安全性",
          "description": "セキュリティ・プライバシー・信頼性・堅牢性",
          "scoring_rubric": "0-20: 重大な脆弱性、20-40: いくつかのセキュリティ問題、40-60: 平均的なセキュリティ、60-80: 強固なセキュリティ、80-100: 最高レベルのセキュリティ"
        },
        {
          "name": "倫理",
          "description": "バイアス・透明性・説明責任・社会的影響",
          "scoring_rubric": "0-20: 重大な倫理的懸念、20-40: いくつかの倫理的問題、40-60: 平均的な倫理基準、60-80: 強い倫理的配慮、80-100: 最高水準の倫理基準"
        },
        {
          "name": "コスト",
          "description": "導入コスト・運用コスト・ROI・価格競争力",
          "scoring_rubric": "0-20: 非常に高額、20-40: 高額、40-60: 平均的な価格、60-80: 低価格、80-100: 非常に低価格・高ROI"
        },
        {
          "name": "革新性",
          "description": "新規性・差別化・将来性・技術的進歩",
          "scoring_rubric": "0-20: 既存技術の焼き直し、20-40: わずかな改善、40-60: 平均的な革新性、60-80: 革新的、80-100: 業界を変える革新"
        }
      ]
    }
  },
